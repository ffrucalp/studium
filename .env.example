# ─── Studium Environment Variables ─────────────────────────────────

# Cloudflare Worker base URL
VITE_API_URL=https://studium-api.francisco-fernandezr.workers.dev

# OpenRouter API key (para dev local)
VITE_OPENROUTER_KEY=

# Modelo de IA (default: arcee-ai/trinity-large-preview:free)
VITE_AI_MODEL=arcee-ai/trinity-large-preview:free

# Google OAuth Client ID (de Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=

# Google Calendar/Gmail/Drive se habilitan automáticamente con el login de Google
